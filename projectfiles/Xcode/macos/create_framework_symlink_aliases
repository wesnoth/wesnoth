#!/bin/sh

# Xcode provides TARGET_BUILD_DIR, FRAMEWORKS_FOLDER_PATH, EXECUTABLE_FOLDER_PATH,
# and PROJECT_DIR for this build phase. The script needs the bundled
# Frameworks dir, the app's executable dir, plus the dependency dir under
# projectfiles/Xcode/lib produced by build_macos_deps.
frameworks_dir="${TARGET_BUILD_DIR}/${FRAMEWORKS_FOLDER_PATH}"
macos_dir="${TARGET_BUILD_DIR}/${EXECUTABLE_FOLDER_PATH}"
source_lib_dir="${PROJECT_DIR}/lib"

choose_candidate() {
	dep_name="$1"
	search_dir="$2"
	prefix="${dep_name%.dylib}"
	resolved_name=""
	resolved_suffix=""
	for candidate in "${search_dir}/${prefix}".*.dylib "${search_dir}/${prefix}"-*.dylib; do
		[ -e "${candidate}" ] || continue
		candidate_name="$(basename "${candidate}")"
		candidate_suffix="${candidate_name#"${prefix}"}"
		# When the staged bundle contains both an app-bundle filename and a more
		# specific filename, such as libreadline.8.dylib and
		# libreadline.8.3.dylib, prefer the shorter suffix after the shared
		# stem. That keeps recreated app-bundle aliases aligned with the
		# @rpath/@loader_path names other bundled dylibs refer to.
		if [ -z "${resolved_name}" ] || [ ${#candidate_suffix} -lt ${#resolved_suffix} ]; then
			resolved_name="${candidate_name}"
			resolved_suffix="${candidate_suffix}"
		fi
	done
	printf '%s' "${resolved_name}"
}

sign_dependency() {
	dylib_path="$1"
	codesign --force --sign - --timestamp=none "${dylib_path}"
}

resolve_dependency_name() {
	dep_name="$1"
	resolved_name="$(choose_candidate "${dep_name}" "${frameworks_dir}")"
	if [ -z "${resolved_name}" ]; then
		src_path="${source_lib_dir}/${dep_name}"
		if [ -L "${src_path}" ]; then
			target_name="$(basename "$(readlink "${src_path}")")"
			if [ -e "${source_lib_dir}/${target_name}" ]; then
				resolved_name="${target_name}"
			fi
		elif [ -e "${src_path}" ]; then
			resolved_name="${dep_name}"
		fi
	fi

	if [ -z "${resolved_name}" ]; then
		resolved_name="$(choose_candidate "${dep_name}" "${source_lib_dir}")"
	fi
	[ -n "${resolved_name}" ] || return 1
	printf '%s\n' "${resolved_name}"
}

ensure_dependency_present() {
	dep_name="$1"
	resolved_name="$(resolve_dependency_name "${dep_name}")" || return 1
	if [ ! -e "${frameworks_dir}/${resolved_name}" ]; then
		cp -p "${source_lib_dir}/${resolved_name}" "${frameworks_dir}/${resolved_name}"
	fi
	if [ "${dep_name}" != "${resolved_name}" ] && [ ! -e "${frameworks_dir}/${dep_name}" ]; then
		ln -sf "${resolved_name}" "${frameworks_dir}/${dep_name}"
	fi
	printf '%s\n' "${resolved_name}"
}

processed_dylibs="|"

has_processed_dylib() {
	case "${processed_dylibs}" in
		*"|$1|"*)
			return 0
			;;
		*)
			return 1
			;;
	esac
}

mark_processed_dylib() {
	processed_dylibs="${processed_dylibs}$1|"
}

scan_binary_dependencies() {
	binary_path="$1"
	while IFS= read -r line; do
		dep="$(printf '%s\n' "${line}" | sed 's/^[[:space:]]*//; s/ (compatibility.*$//')"
		case "${dep}" in
			@loader_path/*|@rpath/*)
				dep_name="$(basename "${dep}")"
				if [ ! -e "${frameworks_dir}/${dep_name}" ]; then
					resolved_name="$(ensure_dependency_present "${dep_name}")" || return 1
					scan_dylib_tree "${resolved_name}" || return 1
				fi
				;;
		esac
	done <<EOF
$(otool -L "${binary_path}" | sed '1d')
EOF
}

scan_dylib_tree() {
	dylib_name="$1"

	has_processed_dylib "${dylib_name}" && return 0
	mark_processed_dylib "${dylib_name}"

	scan_binary_dependencies "${frameworks_dir}/${dylib_name}" || return 1
}

# Walk copied dylibs directly so newly added dependencies are scanned as soon as
# they appear, instead of rescanning the whole Frameworks dir until it stops
# changing.
for dylib in "${frameworks_dir}"/*.dylib; do
	[ -e "${dylib}" ] || continue
	[ -L "${dylib}" ] && continue
	scan_dylib_tree "$(basename "${dylib}")" || exit 1
done

# Some dependencies are only referenced by the app's executables, not by other
# bundled dylibs. Scan those binaries too so fully versioned @rpath edges such
# as libreadline.8.3.dylib are copied into Frameworks before launch.
if [ -d "${macos_dir}" ]; then
	for binary in "${macos_dir}"/*; do
		[ -e "${binary}" ] || continue
		[ -d "${binary}" ] && continue
		[ -L "${binary}" ] && continue
		scan_binary_dependencies "${binary}" || exit 1
	done
fi

recreate_alias() {
	link_name="$1"
	target_name="$2"

	if [ -n "${target_name}" ] && [ -e "${frameworks_dir}/${target_name}" ] && [ ! -e "${link_name}" ]; then
		ln -sf "${target_name}" "${link_name}"
		return 0
	fi

	resolved_name="$(choose_candidate "${link_name}" "${frameworks_dir}")"
	if [ -n "${resolved_name}" ] && [ ! -e "${link_name}" ]; then
		ln -sf "${resolved_name}" "${link_name}"
	fi
}

cd "${frameworks_dir}" || exit 1
# projectfiles/Xcode/lib contains compatibility-name symlinks that Xcode does
# not preserve when it copies dylibs into the app bundle, so recreate them here.
for link_path in "${source_lib_dir}"/*.dylib; do
	[ -L "${link_path}" ] || continue
	link_name="$(basename "${link_path}")"
	target_name="$(basename "$(readlink "${link_path}")")"
	recreate_alias "${link_name}" "${target_name}"
done

recreate_alias "libz.1.dylib" ""

for dylib in "${frameworks_dir}"/*.dylib; do
	[ -e "${dylib}" ] || continue
	[ -L "${dylib}" ] && continue
	sign_dependency "${dylib}"
done
