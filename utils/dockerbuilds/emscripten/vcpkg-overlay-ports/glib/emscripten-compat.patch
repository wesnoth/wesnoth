diff --git a/glib/gconvert.c b/glib/gconvert.c
index 367e9b4..58b83a7 100644
--- a/glib/gconvert.c
+++ b/glib/gconvert.c
@@ -186,7 +186,20 @@ g_iconv (GIConv   converter,
 {
   iconv_t cd = (iconv_t)converter;
 
+#ifdef __EMSCRIPTEN__
+  size_t inleft = inbytes_left ? (size_t)*inbytes_left : 0;
+  size_t outleft = outbytes_left ? (size_t)*outbytes_left : 0;
+  size_t result = iconv (cd,
+			 inbuf, inbytes_left ? &inleft : NULL,
+			 outbuf, outbytes_left ? &outleft : NULL);
+  if (inbytes_left)
+    *inbytes_left = (gsize)inleft;
+  if (outbytes_left)
+    *outbytes_left = (gsize)outleft;
+  return (gsize)result;
+#else
   return iconv (cd, inbuf, inbytes_left, outbuf, outbytes_left);
+#endif
 }
 
