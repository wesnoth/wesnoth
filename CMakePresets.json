{
  "version": 3,
  "configurePresets": [
    {
      "name": "windows-base",
      "description": "Target Windows with the Visual Studio development environment.",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/out/build/${presetName}",
      "installDir": "${sourceDir}/out/install/${presetName}",
      "toolchainFile": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "cl.exe",
        "CMAKE_CXX_COMPILER": "cl.exe"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "x64-Debug",
      "displayName": "x64 Debug",
      "description": "Target Windows (64-bit) with the Visual Studio development environment. (Debug)",
      "inherits": "windows-base",
      "architecture": {
        "value": "x64",
        "strategy": "external"
      },
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Debug" }
    },
    {
      "name": "x64-Release",
      "displayName": "x64 Release",
      "description": "Target Windows (64-bit) with the Visual Studio development environment. (RelWithDebInfo)",
      "inherits": "x64-Debug",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "RelWithDebInfo" }
    },
    {
      "name": "web-emscripten-base",
      "description": "Base preset for building Wesnoth with Emscripten.",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/out/build/${presetName}",
      "installDir": "${sourceDir}/out/install/${presetName}",
      "toolchainFile": "$env{EMSCRIPTEN}/cmake/Modules/Platform/Emscripten.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "CMAKE_EXECUTABLE_SUFFIX": ".html",
        "ENABLE_SERVER": "OFF",
        "ENABLE_CAMPAIGN_SERVER": "OFF",
        "ENABLE_TESTS": "OFF",
        "ENABLE_NLS": "OFF",
        "ENABLE_POT_UPDATE_TARGET": "OFF",
        "ENABLE_DISPLAY_REVISION": "OFF",
        "ENABLE_NOTIFICATIONS": "OFF",
        "ENABLE_DESKTOP_ENTRY": "OFF",
        "ENABLE_APPDATA_FILE": "OFF"
      }
    },
    {
      "name": "web-emscripten",
      "displayName": "Web Emscripten",
      "description": "Build Wesnoth for WebAssembly without pthreads.",
      "inherits": "web-emscripten-base",
      "cacheVariables": {
        "CMAKE_C_FLAGS": "-sWASM=1 -sALLOW_MEMORY_GROWTH=1 -sFORCE_FILESYSTEM=1",
        "CMAKE_CXX_FLAGS": "-sWASM=1 -sALLOW_MEMORY_GROWTH=1 -sFORCE_FILESYSTEM=1",
        "CMAKE_EXE_LINKER_FLAGS": "-sWASM=1 -sALLOW_MEMORY_GROWTH=1 -sFORCE_FILESYSTEM=1"
      }
    },
    {
      "name": "web-emscripten-sab",
      "displayName": "Web Emscripten (SAB)",
      "description": "Build Wesnoth for WebAssembly with SharedArrayBuffer (pthreads).",
      "inherits": "web-emscripten-base",
      "cacheVariables": {
        "CMAKE_C_FLAGS": "-pthread -sUSE_PTHREADS=1 -sPTHREAD_POOL_SIZE=4 -sPROXY_TO_PTHREAD=1 -sWASM=1 -sALLOW_MEMORY_GROWTH=1 -sFORCE_FILESYSTEM=1",
        "CMAKE_CXX_FLAGS": "-pthread -sUSE_PTHREADS=1 -sPTHREAD_POOL_SIZE=4 -sPROXY_TO_PTHREAD=1 -sWASM=1 -sALLOW_MEMORY_GROWTH=1 -sFORCE_FILESYSTEM=1",
        "CMAKE_EXE_LINKER_FLAGS": "-pthread -sUSE_PTHREADS=1 -sPTHREAD_POOL_SIZE=4 -sPROXY_TO_PTHREAD=1 -sWASM=1 -sALLOW_MEMORY_GROWTH=1 -sFORCE_FILESYSTEM=1"
      }
    }
  ]
}
