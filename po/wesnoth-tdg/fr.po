#. [message]: speaker=Kalenz
#: data/campaigns/The_Deceivers_Gambit/utils/unified_characters.cfg:604
#, fuzzy
msgid "Nobody can cheat death forever..."
msgstr "Nul ne peut tromper la mort éternellement..."

