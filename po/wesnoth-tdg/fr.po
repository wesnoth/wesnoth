#: data/campaigns/The_Deceivers_Gambit/scenarios/07_The_Great_River.cfg:832
#: data/campaigns/The_Deceivers_Gambit/scenarios/07_The_Great_River.cfg:843
#, fuzzy
msgid "I sssaid, light the fire!"
msgstr "J'ai dit : allumez le feu !"

#. [event]
#: data/campaigns/The_Deceivers_Gambit/scenarios/07_The_Great_River.cfg:835
#, fuzzy
msgid ""
"Cursssesss, the mountain guards are ssslain, and the beacon cannot be "
"reached!"
msgstr ""
"Mince alors ! Les gardes de la montagne ont été tués, et le flambeau est "
"inaccessible !"

#. [event]
#: data/campaigns/The_Deceivers_Gambit/scenarios/07_The_Great_River.cfg:845
#, fuzzy
msgid "Cursssesss, the beacon is destroyed and the orcs still slumber!"
msgstr ""
"Maudit soit-il, le flambeau est détruit et les orcs roupillent encore !"

#. [message]: role=goblin1
#: data/campaigns/The_Deceivers_Gambit/scenarios/07_The_Great_River.cfg:866
#, fuzzy
msgid "Eeek! It’s gone!"
msgstr "Aah ! Il a disparu !"

#. [message]: speaker=Ysaxis
#. no matter, my saurains will slip past and warn the army! Everyone, escape to the west!
#: data/campaigns/The_Deceivers_Gambit/scenarios/07_The_Great_River.cfg:872
#, fuzzy
msgid ""
" No matter, my sssaurians will ssslip past and warn the army! Everyone, "
"essscape to the west!"
msgstr ""
"Peu importe, mes sssauriens se faufileront et avertiront l'armée ! Fuyez "
"tous vers l'ouest !"

#. [message]: speaker=Delfador
#. saurians are trying to run past Delfador's army and get orcs to come fight Delfador
#: data/campaigns/The_Deceivers_Gambit/scenarios/07_The_Great_River.cfg:878
#, fuzzy
msgid ""
"They’re making a run for it! Don’t let a single one get away, or this "
"outpost will be swarming with orcs!"
msgstr ""
"Ils prennent la fuite ! N'en laissez pas échapper un seul, sinon cet avant-"
"poste sera bientôt envahi d'orcs !"

#. [objective]: condition=win
#: data/campaigns/The_Deceivers_Gambit/scenarios/07_The_Great_River.cfg:902
#, fuzzy
msgid "Defeat enemies before any escape"
msgstr "Vaincre les ennemis avant toute fuite."

#. [objective]: condition=lose
#: data/campaigns/The_Deceivers_Gambit/scenarios/07_The_Great_River.cfg:906
#, fuzzy
msgid "Any enemy reaches the west edge of the map"
msgstr "Un ennemi atteint le bord ouest de la carte"

#. [object]
#: data/campaigns/The_Deceivers_Gambit/scenarios/07_The_Great_River.cfg:924
#, fuzzy
msgid "Reselecting Spells:"
msgstr "Resélection des sorts :"

#. [object]
#: data/campaigns/The_Deceivers_Gambit/scenarios/07_The_Great_River.cfg:925
#, fuzzy
msgid ""
"Because the scenario’s objectives have significantly changed (in a way you "
"couldn’t have anticipated at the scenario’s start), you now have the option "
"to change your spells."
msgstr ""
"Étant donné que les objectifs du scénario ont considérablement changé (d'une "
"manière que vous n'auriez pas pu anticiper au début du scénario), vous avez "
