#, fuzzy
msgid "Death of Methor or the Apprentice"
msgstr "Mort de Methor ou de l’apprenti"

#. [note]
#: data/campaigns/The_Deceivers_Gambit/scenarios/01_Stirrings_of_War.cfg:332
#, fuzzy
