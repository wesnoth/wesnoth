#. [message]: speaker=Delfador
#: data/campaigns/The_Deceivers_Gambit/utils/unified_characters.cfg:514
#, fuzzy
msgid "No, it can’t end yet! I have so much left to do..."
msgstr ""
"Non, ça ne peut pas finir maintenant ! J’ai encore tant de choses à "
"accomplir…"

#. [message]: speaker=Delfador
#: data/campaigns/The_Deceivers_Gambit/utils/unified_characters.cfg:525
#, fuzzy
msgid "No! Magic, why have you failed me..."
msgstr "Non ! Magie, pourquoi m’as-tu abandonné…"

#. [message]: speaker=Delfador
#: data/campaigns/The_Deceivers_Gambit/utils/unified_characters.cfg:536
#, fuzzy
msgid "If only I had been a little wiser..."
msgstr "Si seulement j'avais été un peu plus sage..."

#. [message]: speaker=Methor
#: data/campaigns/The_Deceivers_Gambit/utils/unified_characters.cfg:548
#, fuzzy
msgid "War, pain, death... I tried so hard to change things..."
msgstr ""
"Guerre, douleur, mort... J'ai poutant essayé de changer les choses de mon "
"mieux..."

#. [message]: speaker=Deoran
#: data/campaigns/The_Deceivers_Gambit/utils/unified_characters.cfg:560
#, fuzzy
msgid "I have failed my kingdom and my duty..."
msgstr "J'ai manqué à mon royaume et à mon devoir…"

#. [message]: speaker=Garard
#. reference to Shakespeare's Richard III
#: data/campaigns/The_Deceivers_Gambit/utils/unified_characters.cfg:572
#, fuzzy
msgid "A horse! A horse! My kingdom for a horse..."
msgstr "Un cheval ! Un cheval ! Mon royaume pour un cheval…"

#. [message]: speaker=Asheviere
#: data/campaigns/The_Deceivers_Gambit/utils/unified_characters.cfg:582
#, fuzzy
msgid "It’s finally over..."
msgstr "C'est enfin terminé..."

#. [message]: speaker=Lionel
#: data/campaigns/The_Deceivers_Gambit/utils/unified_characters.cfg:592
#, fuzzy
msgid "Blasted orcs..."
