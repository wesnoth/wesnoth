# Translated by openai with model qwen3.5-35b-a3b.
#. [message]: speaker=Delfador
#: data/campaigns/The_Deceivers_Gambit/utils/unified_characters.cfg:575
#, fuzzy
msgid "No! Magic, why have you failed me..."
