#: data/campaigns/The_Deceivers_Gambit/scenarios/04_The_Sylvan_Seer.cfg:649
msgid ""
"This sandbed is shallow, but the water is suddenly deep and a strange magic "
"tugs at my legs! I am drowning!"
msgstr ""

# Translated by openai with model qwen3.5-35b-a3b.
#. [message]
#: data/campaigns/The_Deceivers_Gambit/scenarios/04_The_Sylvan_Seer.cfg:650
msgid ""
"female^This sandbed is shallow, but the water is suddenly deep and a strange "
"magic tugs at my legs! I am drowning!"
msgstr ""

#. [message]
#. a monster has just drowned in the river, as a result of the player redirecting the river into the beast's hex
#: data/campaigns/The_Deceivers_Gambit/scenarios/04_The_Sylvan_Seer.cfg:661
