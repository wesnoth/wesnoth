msgstr "beco stiletto"

#. [attack]: type=blade
#: data/campaigns/Winds_of_Fate/units/Stymphalian.cfg:82
msgid "bladed feathers"
msgstr "penas afiadas"

#. [unit_type]: id=Wyrm, race=monster
