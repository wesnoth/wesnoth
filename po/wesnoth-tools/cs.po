msgid "Run wmllint"
msgstr "Spustit wmllint"

#: data/tools/GUI.pyw:1306
msgid "Save as text..."
msgstr "Uložit jako text..."

#: data/tools/GUI.pyw:1313
msgid "Clear output"
msgstr "Vymazat výstup"

