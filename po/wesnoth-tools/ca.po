#: data/tools/GUI.pyw:89
msgid "Open a Graphical User Interface (GUI) to WML Tools"
msgstr "Obre una interfície gràfica d'usuari (GUI) a les eines WML"

#: data/tools/GUI.pyw:93
msgid ""
"Launch GUI.pyw in the specified language. Language code is expected as a "
"POSIX locale name, refer to gettext.wesnoth.org for a full list."
msgstr ""
"Llança GUI.pyw en el llenguatge especificat. S'espera que el codi de la "
"llengua sigui un nom de configuració regional POSIX; consulteu gettext."
"wesnoth.org per a una llista completa."

