#: data/campaigns/Heir_To_The_Throne/scenarios/23_Northern_Winter.cfg:261
msgid "Defeat a Great Icemonax"
msgstr "Derrota a un Gran Icemonax"

#. [objective]: condition=win
#. [objective]: condition=win, description=<span strikethrough='true'>
#: data/campaigns/Heir_To_The_Throne/scenarios/23_Northern_Winter.cfg:269
#: data/campaigns/Heir_To_The_Throne/scenarios/23_Northern_Winter.cfg:276
msgid "Defeat a Giant Spider"
msgstr "Derrota unha araña xigante"

#. [objective]: condition=win
#. [objective]: condition=win, description=<span strikethrough='true'>
