#. [side]
#: data/campaigns/Heir_To_The_Throne/scenarios/01_The_Elves_Besieged.cfg:756
#: data/campaigns/Heir_To_The_Throne/scenarios/01_The_Elves_Besieged.cfg:777
#: data/campaigns/Heir_To_The_Throne/scenarios/02_Flight_of_the_Elves.cfg:144
msgid "Aethenwood Elves"
msgstr "Elfos de Aethenwood"

#. [event]: id=konrad_silver_crown_object
#. [scenario]: id=08b_Isle_of_the_Damned_part2
#: data/campaigns/Heir_To_The_Throne/scenarios/01_The_Elves_Besieged.cfg:885
#: data/campaigns/Heir_To_The_Throne/scenarios/08b_Isle_of_the_Damned_part2.cfg:108
#: data/campaigns/Heir_To_The_Throne/scenarios/08b_Isle_of_the_Damned_part2.cfg:114
#: data/campaigns/Heir_To_The_Throne/scenarios/08b_Isle_of_the_Damned_part2.cfg:120
#: data/campaigns/Heir_To_The_Throne/scenarios/08b_Isle_of_the_Damned_part2.cfg:126
msgid "60 gold"
msgstr "60 ouro"

#. [event]: id=konrad_silver_crown_object
#. [event]
#: data/campaigns/Heir_To_The_Throne/scenarios/01_The_Elves_Besieged.cfg:886
#: data/campaigns/Heir_To_The_Throne/scenarios/01_The_Elves_Besieged.cfg:887
#: data/campaigns/Heir_To_The_Throne/scenarios/01_The_Elves_Besieged.cfg:888
#: data/campaigns/Heir_To_The_Throne/scenarios/47_Test_of_the_Clans.cfg:194
#: data/campaigns/Heir_To_The_Throne/scenarios/47_Test_of_the_Clans.cfg:195
#: data/campaigns/Heir_To_The_Throne/scenarios/47_Test_of_the_Clans.cfg:196
#: data/campaigns/Heir_To_The_Throne/scenarios/47_Test_of_the_Clans.cfg:197
#: data/campaigns/Heir_To_The_Throne/scenarios/47_Test_of_the_Clans.cfg:198
msgid "30 gold"
msgstr "30 de ouro"

#. [message]: speaker=Konrad {KONRAD_VARIATION concerned}
#: data/campaigns/Heir_To_The_Throne/scenarios/01_The_Elves_Besieged.cfg:1157
msgid ""
"I’m here, Delfador! I thought you were calling me for more training, but "
"there’s smoke rising from the forest. What’s going on?"
msgstr ""
"Estou aquí, Delfador! Pensei que me chamabas para máis adestramento, pero "
"hai fume que sae do bosque. Que está a pasar?"

#. [message]: speaker=Ethiliel
#. human armies have surrounded the Aethenwood and are burning it
#: data/campaigns/Heir_To_The_Throne/scenarios/01_The_Elves_Besieged.cfg:1163
msgid ""
"Trouble from your Queen Asheviere, child! She knows that we sheltered you "
"throughout your youth. Now she comes bearing fiery retribution, and the dawn "
"of a dark age for the Aethenwood."
msgstr ""
"Problemas da túa raíña Asheviere, neno! Ela sabe que che deron refuxio "
"durante toda a túa xuventude. Agora chega portando retribución ardente e o "
"amencer dunha era escura para o Bosque Aethenwood."

#. [message]: speaker=Delfador
#: data/campaigns/Heir_To_The_Throne/scenarios/01_The_Elves_Besieged.cfg:1167
#, fuzzy
#| msgid ""
#| "I have already been injured. I fear she is after you personally, master "
#| "Konrad!"
msgid ""
"I have already been injured. I fear she is after you personally, Master "
"Konrad!"
msgstr "Xa me ferín. Temo que ela o persegue persoalmente, mestre Konrad!"

#. [message]: speaker=Delfador
#: data/campaigns/Heir_To_The_Throne/scenarios/01_The_Elves_Besieged.cfg:1171
msgid ""
"They have us nearly surrounded, but we can still flee to the west. I will "
"protect you!"
msgstr ""
"Teñen case rodeado, pero aínda podemos fuxir cara ao oeste. Eu protexereiche!"

#. [message]: speaker=Konrad {KONRAD_VARIATION concerned}
#: data/campaigns/Heir_To_The_Throne/scenarios/01_The_Elves_Besieged.cfg:1175
msgid "But what about the elves? They are our friends! We have to help fight!"
msgstr ""
"Pero que pasa cos elfos? Son os nosos amigos! Temos que axudar a loitar!"

#. [message]: speaker=Galdrad
#: data/campaigns/Heir_To_The_Throne/scenarios/01_The_Elves_Besieged.cfg:1179
msgid ""
"Asheviere is all of our enemy. We will fight the invaders, but you must "
"escape, Konrad. Lord Kalenz has commanded your safety. It is imperative that "
"you escape!"
msgstr ""
"Asheviere é o noso inimigo total. Loitaremos contra os invasores, pero debes "
"escapar, Konrad. Lord Kalenz ordenou a túa seguridade. É imprescindible que "
"escapes!"

#. [message]: speaker=Delfador
#: data/campaigns/Heir_To_The_Throne/scenarios/01_The_Elves_Besieged.cfg:1183
msgid "Galdrad is right. Do not throw your life away so easily, Your Highness."
msgstr "Galdrad ten razón. Non perda a súa vida tan facilmente, Alteza."

#. [message]: speaker=Delfador
#: data/campaigns/Heir_To_The_Throne/scenarios/01_The_Elves_Besieged.cfg:1187
msgid "There can be no looking back. We must go quickly!"
msgstr "Non podemos mirar atrás. Debemos ir axiña!"

#. [objective]: condition=win
#: data/campaigns/Heir_To_The_Throne/scenarios/01_The_Elves_Besieged.cfg:1199
msgid "Move Konrad and Delfador to the west edge of the map"
msgstr "Mover a Konrad e Delfador ao bordo oeste do mapa"

#. [message]: speaker=Konrad
#: data/campaigns/Heir_To_The_Throne/scenarios/01_The_Elves_Besieged.cfg:1233
msgid "Watch out for the fire!"
msgstr "Coidado co lume!"

#. [message]: speaker=Delfador
#: data/campaigns/Heir_To_The_Throne/scenarios/01_The_Elves_Besieged.cfg:1244
msgid ""
"Konrad, it took you some time to rise this morning. I’m not angry, but I am "
"worried. I won’t always be here to keep you safe!"
msgstr ""
"Konrad, tardaches un pouco en levantarte esta mañá. Non estou enfadado, pero "
"si preocupado. Non estarei sempre aquí para manterte a salvo!"

#. [message]: speaker=Konrad
#. Asheviere and her army are burning the Aethenwood and killing Konrad's elven friends.
#: data/campaigns/Heir_To_The_Throne/scenarios/01_The_Elves_Besieged.cfg:1249
msgid ""
"I know, Delfador, and I’m sorry. This is horrible! How did the fires get so "
"close without me noticing!?"
msgstr ""
"Eu sei, Delfador, e síntoo. Isto é horrible! Como se achegaron tanto os "
"incendios sen que eu me decatase!?"

#. [message]: speaker=Konrad
#. Asheviere and her army are burning the Aethenwood and killing Konrad's elven friends.
#: data/campaigns/Heir_To_The_Throne/scenarios/01_The_Elves_Besieged.cfg:1254
msgid ""
"I’ve never seen so many humans all in one place before. I can’t believe you "
"and I are really the same as them..."
msgstr ""
"Nunca vin tantos humanos nun só lugar. Non podo crer que ti e eu sexamos "
"realmente iguais a eles..."

#. [message]: speaker=Delfador
#: data/campaigns/Heir_To_The_Throne/scenarios/01_The_Elves_Besieged.cfg:1258
msgid ""
"<i><b>I’m</b></i> sorry you couldn’t have grown up among your own people. "
"Our kind can be a little crude, but we aren’t usually so bad — it’s "
"Asheviere who’s stirred up all this mischief."
msgstr ""
"<i><b>Síntoo</b></i> que non puideses medrar entre a túa propia xente. A "
"nosa especie pode ser un pouco groseira, pero normalmente non somos tan "
"mala; é Asheviere quen provocou todas estas travesuras."

#. [message]: speaker=Delfador
#: data/campaigns/Heir_To_The_Throne/scenarios/01_The_Elves_Besieged.cfg:1262
msgid ""
"And if my suspicions are true, this is merely a small part of the greater "
"whole of her armies! We must get out of this forest so we can see what else "
"is going on."
msgstr ""
"E se as miñas sospeitas son certas, isto é só unha pequena parte do conxunto "
"maioritario dos seus exércitos! Temos que saír deste bosque para poder ver "
"que máis está a suceder."

#. [message]: type=Cavalryman # their armored helm looks more intimidating than our Bowman or Spearman portraits
#: data/campaigns/Heir_To_The_Throne/scenarios/01_The_Elves_Besieged.cfg:1274
msgid "Surround the enclaves! Don’t let anyone escape!"
msgstr "Rodea os enclaves! Non deixes que ninguén escape!"

#. [message]: speaker=Galdrad
#: data/campaigns/Heir_To_The_Throne/scenarios/01_The_Elves_Besieged.cfg:1293
msgid "I am Galdrad. You will have to fight me to get any further!"
msgstr "Son Galdrad. Terás que loitar comigo para chegar máis lonxe!"

#. [message]: speaker=Konrad {KONRAD_VARIATION mad}
#. said when Konrad attacks / is attacked
#: data/campaigns/Heir_To_The_Throne/scenarios/01_The_Elves_Besieged.cfg:1314
#, fuzzy
#| msgid "Leave my home alone, you villian!"
msgid "Leave my home alone, you villain!"
msgstr "Deixa a miña casa en paz, vilán!"

#. [message]
#. Asheviere's official stance is that Konrad is a fraud. At this point, the player believes Konrad is the true prince
#: data/campaigns/Heir_To_The_Throne/scenarios/01_The_Elves_Besieged.cfg:1319
#, fuzzy
#| msgid ""
#| "You’re just an imposter! Everyone knows the real prince Konrad died long "
#| "ago."
msgid ""
"You’re just an imposter! Everyone knows the real Prince Konrad died long ago."
msgstr ""
"Ti es só un impostor! Todos saben que o verdadeiro príncipe Konrad morreu "
"hai moito tempo."

#. [message]: speaker=second_unit
#. said when Delfador attacks. The unit flees off the map before Delfador can deal damage
#: data/campaigns/Heir_To_The_Throne/scenarios/01_The_Elves_Besieged.cfg:1332
msgid "Oh no, it’s HIM, it’s Delfador THE GREAT! Get me out of here!"
msgstr "Oh, non, é EL, é o GRANDE Delfador! Sácame de aquí!"

#. [message]: speaker=Delfador
#. an enemy has just fled, even before Delfador got a chance to attack
#: data/campaigns/Heir_To_The_Throne/scenarios/01_The_Elves_Besieged.cfg:1354
msgid "My reputation precedes me."
msgstr "A miña reputación precedeime."

#. [message]: speaker=Delfador
#. Delfador has killed 10 enemies, and the player has earned an achievement
#: data/campaigns/Heir_To_The_Throne/scenarios/01_The_Elves_Besieged.cfg:1381
msgid "Only fools dare oppose me."
msgstr "Só os tolos se atreven a opoñerse a min."

#. [message]: speaker=narrator
#: data/campaigns/Heir_To_The_Throne/scenarios/01_The_Elves_Besieged.cfg:1395
msgid ""
"Wow, you’ve defeated all the invaders and saved the Aethenwood! I didn’t "
"expect this to be possible, so if you’re reading this message in-game you’ve "
"exceeded all expectations! (or you’re cheating to see what happens / using "
"overpowered add-ons)"
msgstr ""
"Uau, derrotaches a todos os invasores e salvaste o Bosque Aethen! Non "
"esperaba que isto fose posible, así que se estás a ler esta mensaxe no xogo, "
"superaches todas as expectativas! (ou estás a facer trampas para ver que "
"pasa / a usar complementos excesivamente potentes)"

#. [message]: speaker=narrator
#: data/campaigns/Heir_To_The_Throne/scenarios/01_The_Elves_Besieged.cfg:1400
msgid ""
"Unfortunately this breaks the story, so for the rest of the campaign we’re "
"going to have to pretend that this never happened, okay?"
msgstr ""
"Por desgraza isto rompe a historia, así que durante o resto da campaña "
"teremos que facer coma se isto nunca tivese pasado, vale?"

#. [message]: speaker=Isolde
#: data/campaigns/Heir_To_The_Throne/scenarios/01_The_Elves_Besieged.cfg:1413
msgid "Impossible! I must report back to the queen."
msgstr "Imposible! Débolle informe á raíña."

#. [message]: speaker=Konrad
#: data/campaigns/Heir_To_The_Throne/scenarios/01_The_Elves_Besieged.cfg:1436
msgid "Hurry, Delfador! I’m not leaving without you."
msgstr "Depresa, Delfador! Non me vou ir sen ti."

#. [message]: speaker=Delfador
#: data/campaigns/Heir_To_The_Throne/scenarios/01_The_Elves_Besieged.cfg:1450
msgid "Hurry along, Konrad! We leave together, or not at all."
msgstr "Apresúrate, Konrad! Marchamos xuntos, ou non marchamos."

#. [message]: speaker=Delfador
#: data/campaigns/Heir_To_The_Throne/scenarios/01_The_Elves_Besieged.cfg:1476
msgid "Time to go, Konrad! Come on!"
msgstr "É hora de marchar, Konrad! Anda!"

#. [message]: speaker=Konrad {KONRAD_VARIATION concerned}
#: data/campaigns/Heir_To_The_Throne/scenarios/01_The_Elves_Besieged.cfg:1480
msgid ""
"Of course you are right, Delfador. But what will become of our friends here?"
msgstr "Claro que tes razón, Delfador. Pero que será dos nosos amigos de aquí?"

#. [message]: speaker=Delfador
#: data/campaigns/Heir_To_The_Throne/scenarios/01_The_Elves_Besieged.cfg:1484
msgid ""
"The elves will fight. They may even prevail. But I fear things do not bode "
"well for them. Let us not speak of it now. Onward!"
msgstr ""
"Os elfos loitarán. Incluso poden prevalecer. Pero temo que as cousas non "
"auguran nada bo para eles. Non falemos diso agora. Adiante!"

#. [message]: speaker=Delfador
#: data/campaigns/Heir_To_The_Throne/scenarios/01_The_Elves_Besieged.cfg:1500
msgid "Hurry, hurry! We have but a moment left."
msgstr "Rápido, rápido! Só nos queda un intre."

#. [message]: role=halberdier
#: data/campaigns/Heir_To_The_Throne/scenarios/01_The_Elves_Besieged.cfg:1511
msgid ""
"General, we’ve seized the western forest and occupied the elf-roads! The "
"rest of the men will be here shortly."
msgstr ""
"Xeneral, tomamos o bosque occidental e ocupamos os camiños élficos! O resto "
"dos homes chegará axiña."

#. [message]: speaker=Delfador
#: data/campaigns/Heir_To_The_Throne/scenarios/01_The_Elves_Besieged.cfg:1515
msgid "We have run out of time! There can be no more escape..."
msgstr "Quedamos sen tempo! Xa non hai máis escapatoria..."

#. [scenario]
#: data/campaigns/Heir_To_The_Throne/scenarios/02_Flight_of_the_Elves.cfg:19
msgid "Flight of the Elves"
msgstr "Voo dos Elfos"

#. [event]
#: data/campaigns/Heir_To_The_Throne/scenarios/02_Flight_of_the_Elves.cfg:192
msgid "Quillan"
msgstr "Quillan"

#. [unit]: id=Tanyth, type=Elvish Avenger, gender=female
#: data/campaigns/Heir_To_The_Throne/scenarios/02_Flight_of_the_Elves.cfg:210
msgid "Tanyth"
msgstr "Tanyth"

#. [message]: speaker=Quillan
#: data/campaigns/Heir_To_The_Throne/scenarios/02_Flight_of_the_Elves.cfg:251
msgid ""
"Master Konrad, I am pleased to see that you have escaped! And even more "
"pleased to see that you have returned."
msgstr ""
"Mestre Konrad, alégrame ver que escapaches! E aínda máis alégrame ver que "
"volveches."

#. [message]: speaker=Delfador
#: data/campaigns/Heir_To_The_Throne/scenarios/02_Flight_of_the_Elves.cfg:256
#, fuzzy
#| msgid ""
#| "What is the matter, Quillan? We had planned for you to all go into hiding "
#| "after Konrad and I fled, if you could not defeat the attackers. Yet the "
#| "fighting continues.\n"
#| "\n"
#| "I suspect Elensefar to be under siege as well — I cannot leave Maddock to "
#| "fight alone, yet neither can I leave you elves to be slaughtered."
msgid ""
"What is the matter, Quillan? We had planned for you to all go into hiding "
"after Konrad and I fled, if you could not defeat the attackers. Yet the "
"fighting continues."
msgstr ""
"Que pasa, Quillan? Tiñamos previsto que todos vós vos agochásedes despois de "
"que Konrad e eu fuxísemos, se non puidesedes derrotar aos atacantes. Con "
"todo, a loita continúa. Sospeito que Elensefar tamén está sitiada — non podo "
"deixar a Maddock loitar só, pero tampouco podo deixarvos a vós, os elfos, "
"ser masacrados."

#. [message]: speaker=Delfador
#: data/campaigns/Heir_To_The_Throne/scenarios/02_Flight_of_the_Elves.cfg:258
#, fuzzy
#| msgid ""
#| "How soon, Kaylan? I suspect Elensefar to be under siege as well — I "
#| "cannot leave Maddock to fight alone, yet neither can I leave the prince "
#| "unguarded."
msgid ""
"I suspect Elensefar to be under siege as well — I cannot leave Maddock to "
"fight alone, yet neither can I leave you elves to be slaughtered."
msgstr ""
"Canto tempo tardará, Kaylan? Sospeito que Elensefar tamén está asediada. Non "
"podo deixar a Maddock loitando só, pero tampouco podo deixar ao príncipe "
"desatendido."

#. [message]: speaker=Konrad {KONRAD_VARIATION concerned}
#: data/campaigns/Heir_To_The_Throne/scenarios/02_Flight_of_the_Elves.cfg:263
msgid ""
"Quillan, what’s going on? You were all to have gone into hiding after I "
"fled, if you could not defeat the attackers, but I still see fires and "
"fighting in the distance!"
msgstr ""
"Quillan, que está a pasar? Todos vós tiñades que agocharvos despois de que "
"eu fuxise, se non puidérades derrotar os atacantes, pero aínda vexo fogos e "
"loitas ao lonxe!"

#. [message]: speaker=Quillan
#: data/campaigns/Heir_To_The_Throne/scenarios/02_Flight_of_the_Elves.cfg:268
msgid ""
"Our lines have been broken; men pour into the Aethenwood. The marshals are "
"coordinating a retreat, but are being harried at every step."
msgstr ""
"As nosas liñas foron rotas; os homes entran en masa no Bosque de Aethen. Os "
"mariscais están a coordinar unha retirada, pero están a ser acosados a cada "
"paso."

#. [message]: speaker=leader4
#: data/campaigns/Heir_To_The_Throne/scenarios/02_Flight_of_the_Elves.cfg:272
msgid "Don’t let them get away! The queen demands a total victory!"
msgstr "Non os deixes escapar! A raíña esixe unha vitoria total!"

#. [message]: speaker=leader3
#: data/campaigns/Heir_To_The_Throne/scenarios/02_Flight_of_the_Elves.cfg:276
msgid ""
"Kill any who resist, but take the rest alive. We need prisoners for "
"interrogation and slaves for the mines!"
msgstr ""
"Matade a calquera que se resista, pero collede vivos aos demais. Necesitamos "
"prisioneiros para os interrogatorios e escravos para as minas!"

#. [message]: speaker=Quillan
#: data/campaigns/Heir_To_The_Throne/scenarios/02_Flight_of_the_Elves.cfg:282
msgid ""
"My riders and I are the first to break free of our encirclement! We are "
"swift enough to escape the spears, but our slower brethren may be caught as "
"they retreat."
msgstr ""
"Os meus xinetes e eu somos os primeiros en liberarnos do noso cerco! Somos "
"rápidos dabondo para escapar das lanzas, pero os nosos irmáns máis lentos "
"poden ser capturados na súa retirada."

#. [message]: speaker=Quillan
#: data/campaigns/Heir_To_The_Throne/scenarios/02_Flight_of_the_Elves.cfg:286
msgid ""
"They will be here soon. Konrad, you must help us all reach safety across the "
"river!"
msgstr ""
"Estarán aquí pronto. Konrad, tes que axudarnos a todos a chegar a salvo á "
"outra beira do río!"

#. [objective]: condition=win
#. $dead_elves is a number; probably between 0 and 20
#: data/campaigns/Heir_To_The_Throne/scenarios/02_Flight_of_the_Elves.cfg:297
msgid "Survive until all elves escape or die ($dead_elves dead so far)"
msgstr ""
"Sobrevivir ata que todos os elfos escapen ou morran ($dead_elves dead so now)"

#. [objective]: condition=win
#. [objective]: condition=win, description=<span strikethrough='true' color='#A9A9A9'>
#. if 15 or fewer elves die, Konrad will learn to recruit Elvish Archers
#: data/campaigns/Heir_To_The_Throne/scenarios/02_Flight_of_the_Elves.cfg:303
#: data/campaigns/Heir_To_The_Throne/scenarios/02_Flight_of_the_Elves.cfg:310
msgid "15 or fewer deaths: recruit Elvish Archers"
msgstr "15 mortes ou menos: recruta arqueiros élficos"

#. [objective]: condition=win
#. [objective]: condition=win, description=<span strikethrough='true' color='#A9A9A9'>
#. if 10 or fewer elves die, Konrad will learn to recruit Elvish Scouts
#: data/campaigns/Heir_To_The_Throne/scenarios/02_Flight_of_the_Elves.cfg:319
#: data/campaigns/Heir_To_The_Throne/scenarios/02_Flight_of_the_Elves.cfg:326
msgid "10 or fewer deaths: recruit Elvish Scouts"
msgstr "10 mortes ou menos: recruta exploradores élficos"

#. [objective]: condition=win, description=  
#. [objective]: condition=win, description=<span strikethrough='true' color='#A9A9A9'>  
#. if 5 or fewer elves die, Konrad will learn to recruit Elvish Fighters
#: data/campaigns/Heir_To_The_Throne/scenarios/02_Flight_of_the_Elves.cfg:336
#: data/campaigns/Heir_To_The_Throne/scenarios/02_Flight_of_the_Elves.cfg:343
msgid "5 or fewer deaths: recruit Elvish Fighters"
msgstr "5 ou menos mortes: recluta loitadores elficos"

#. [message]: speaker=Konrad
#: data/campaigns/Heir_To_The_Throne/scenarios/02_Flight_of_the_Elves.cfg:380
msgid ""
"The elves are going south across the river, but we must stand our ground and "
"help them escape!"
msgstr ""
"Os elfos van cara ao sur a través do río, pero nós debemos manternos firmes "
"e axudalos a escapar!"

#. [message]: speaker=unit
#: data/campaigns/Heir_To_The_Throne/scenarios/02_Flight_of_the_Elves.cfg:403
msgid "I have reached the southern shore! Scatter into the deep forest!"
msgstr "Cheguei á costa sur! Espalladevos polo bosque profundo!"

#. [message]: speaker=Konrad {KONRAD_VARIATION concerned}
#: data/campaigns/Heir_To_The_Throne/scenarios/02_Flight_of_the_Elves.cfg:417
msgid ""
"Will none of you stay and help fight? If we all stand together, surely we "
"can resist the invaders!"
msgstr ""
"¿Ningún de vós se queda a axudar a loitar? Se todos nos unimos, surely "
"poderemos resistir aos invasores!"

#. [message]: speaker=unit
#: data/campaigns/Heir_To_The_Throne/scenarios/02_Flight_of_the_Elves.cfg:421
msgid ""
"To stand together is to fall together, Konrad. We defended our homes in the "
"east as best we could, but now the decision has been made to scatter, not to "
"fight."
msgstr ""
"Estar xuntos é caer xuntos, Konrad. Defendemos as nosas casas no leste o "
"mellor que puidemos, pero agora tomouse a decisión de dispersarse, non de "
"loitar."

#. [message]: speaker=unit
#: data/campaigns/Heir_To_The_Throne/scenarios/02_Flight_of_the_Elves.cfg:425
msgid ""
"The Aethenwood is but a backwater compared to Wesmere or the Lintanir; the "
"might of Wesnoth is beyond our capacity to withstand. We must scatter and "
"hide if we wish any hope of evading your kin."
msgstr ""
"O Bosque de Aethen non é máis que un remanso comparado con Wesmere ou o "
"Lintanir; o poder de Wesnoth está máis alá da nosa capacidade para resistir. "
"Debemos dispersarnos e agocharnos se queremos algunha esperanza de escapar "
"da vosa raza."

#. [message]: role=speaker {FILTER_LOCATION x,y,radius=44,7,4}
#: data/campaigns/Heir_To_The_Throne/scenarios/02_Flight_of_the_Elves.cfg:449
msgid ""
"Be swift, friends. We must cross the river and vanish into the southern "
"woods before our pursuers catch us!"
msgstr ""
"Sede rápidos, amigos. Debemos cruzar o río e desaparecer nos bosques do sur "
"antes de que os nosos perseguidores nos atrapen!"

#. [message]: speaker=leader3
#: data/campaigns/Heir_To_The_Throne/scenarios/02_Flight_of_the_Elves.cfg:470
#, fuzzy
#| msgid "Where are my fencers They should have started their attack by now."
msgid "Where are my fencers? They should have started their attack by now."
msgstr "Onde están os meus esgrimistas? Xa deberían ter comezado o seu ataque."

#. [event]
#: data/campaigns/Heir_To_The_Throne/scenarios/02_Flight_of_the_Elves.cfg:475
msgid "Aramis"
msgstr "Aramis"

#. [message]: speaker=leader6
#: data/campaigns/Heir_To_The_Throne/scenarios/02_Flight_of_the_Elves.cfg:482
msgid ""
"Sorry for the delay, Lieutenant! We’re finally in position, and ready to "
"help intercept the elves."
msgstr ""
"Desculpa o atraso, tenente! Por fin estamos en posición e listos para axudar "
"a interceptar os elfos."

#. [message]: speaker=Konrad
#: data/campaigns/Heir_To_The_Throne/scenarios/02_Flight_of_the_Elves.cfg:518
msgid ""
"How many more elves are left to evacuate from the east-halls? We cannot keep "
"fighting forever!"
msgstr ""
"Cantos elfos máis quedan por evacuar dos salóns do leste? Non podemos seguir "
"loitando para sempre!"

#. [message]: role=speaker {FILTER_LOCATION x,y,radius=44,7,4}
#: data/campaigns/Heir_To_The_Throne/scenarios/02_Flight_of_the_Elves.cfg:523
msgid ""
"Not many. Galdrad is managing the rest of the retreat — you will see him "
"soon!"
msgstr ""
"Non moitos. Galdrad está a xestionar o resto do retiro. Verédelo pronto!"

#. [message]: role=speaker {FILTER_LOCATION x,y,radius=44,7,4}
#: data/campaigns/Heir_To_The_Throne/scenarios/02_Flight_of_the_Elves.cfg:529
msgid ""
"Not many. Ethiliel is managing the rest of the retreat — you will see her "
"soon!"
msgstr ""
"Non moitos. Ethiliel está a xestionar o resto do retiro. Verémola pronto!"

#. [message]: role=speaker {FILTER_LOCATION x,y,radius=44,7,4}
#: data/campaigns/Heir_To_The_Throne/scenarios/02_Flight_of_the_Elves.cfg:535
msgid ""
"Not many. Tanyth is managing the rest of the retreat — you will see her soon!"
msgstr ""
"Non moitos. Tanyth está a xestionar o resto do retiro. Verémola pronto!"

#. [message]: id=$elf_leader.id
#: data/campaigns/Heir_To_The_Throne/scenarios/02_Flight_of_the_Elves.cfg:564
msgid ""
"Konrad, I lead the last of the evacuees — we shall make for the ford at "
"once. But be wary, for the human general comes nipping at our heels!"
msgstr ""
"Konrad, eu lidero os últimos evacuados. Iremos ao vao de inmediato. Pero "
"tede coidado, porque o xeneral humano vén pisándonos os talóns!"

#. [message]: id=$elf_leader.id
#: data/campaigns/Heir_To_The_Throne/scenarios/02_Flight_of_the_Elves.cfg:565
#, fuzzy
#| msgid ""
#| "Konrad, I lead the last of the evacuees — we shall make for the ford at "
#| "once. But be wary, for the human general comes nipping at our heels!"
msgid ""
"female^Konrad, I lead the last of the evacuees — we shall make for the ford "
"at once. But be wary, for the human general comes nipping at our heels!"
msgstr ""
"Konrad, eu lidero os últimos evacuados. Iremos ao vao de inmediato. Pero "
"tede coidado, porque o xeneral humano vén pisándonos os talóns!"

#. [message]: speaker=Isolde
#: data/campaigns/Heir_To_The_Throne/scenarios/02_Flight_of_the_Elves.cfg:577
msgid ""
"Keep pushing forward — don’t let any more of them escape. Twenty gold pieces "
"for whoever takes the head of their leader!"
msgstr ""
"Seguide avanzando. Non deixedes escapar máis. Vinte moedas de ouro para quen "
"colla a cabeza do seu líder!"

#. [message]: speaker=Isolde
#: data/campaigns/Heir_To_The_Throne/scenarios/02_Flight_of_the_Elves.cfg:581
msgid ""
"... is that Konrad? The pretender prince!? He’s returned! We have an "
"opportunity to make up for our previous failure — men, seize him at once!"
msgstr ""
"... é ese Konrad? O príncipe pretendiente!? Volveu! Temos unha oportunidade "
"de compensar o noso fracaso anterior. Homes, apodéreno de inmediato!"

#. [message]: speaker=Konrad {KONRAD_VARIATION mad}
#: data/campaigns/Heir_To_The_Throne/scenarios/02_Flight_of_the_Elves.cfg:648
msgid "You should never have attacked my home, you villain!"
msgstr "Nunca deberías ter atacado a miña casa, vilán!"

#. [message]: speaker=Konrad {KONRAD_VARIATION glad}
#: data/campaigns/Heir_To_The_Throne/scenarios/02_Flight_of_the_Elves.cfg:656
msgid ""
"That’s the last of their leaders defeated! With Wesnoth beaten back, even if "
"only temporarily, the rest of the elves can safely evacuate."
msgstr ""
"Ese é o último dos seus líderes derrotados! Con Wesnoth derrotado, aínda que "
"só sexa temporalmente, o resto dos elfos poden evacuar con seguridade."

#. [message]: role=victory_speaker
#: data/campaigns/Heir_To_The_Throne/scenarios/02_Flight_of_the_Elves.cfg:682
msgid ""
"Scatter to the south; scatter to the west! Spread ourselves in hiding across "
"the entire wood, and they shall never be able to root us out."
msgstr ""
"Disperse cara ao sur; disperse cara ao oeste! Espalleigámonos agochados por "
"todo o bosque, e nunca poderán extirparnos de raíz."

#. [message]: role=victory_speaker
#: data/campaigns/Heir_To_The_Throne/scenarios/02_Flight_of_the_Elves.cfg:710
msgid ""
"You have my gratitude, friend Konrad. Without your help, this would surely "
"have been a great slaughter. Allow us to aid you in return."
msgstr ""
"Tes o meu agradecemento, amigo Konrad. Sen a túa axuda, isto sen dúbida "
"tería sido unha gran matanza. Permítenos axudarche a cambio."

#. [message]: role=victory_speaker
#: data/campaigns/Heir_To_The_Throne/scenarios/02_Flight_of_the_Elves.cfg:717
msgid ""
"With so many of our number safely escaped, our archers, fighter, and scouts "
"all stand ready to join you on your journey!"
msgstr ""
"Con tantos dos nosos escapados con seguridade, os nosos arqueiros, o "
"guerreiro e os exploradores están todos preparados para unirse a vós na vosa "
"viaxe!"

#. [then]
#: data/campaigns/Heir_To_The_Throne/scenarios/02_Flight_of_the_Elves.cfg:719
msgid "Konrad can now recruit Elvish Archers, Fighters, and Scouts!"
msgstr ""
"Konrad agora pode recrutar arqueiros, guerreiros e exploradores élficos!"

#. [message]: role=victory_speaker
#: data/campaigns/Heir_To_The_Throne/scenarios/02_Flight_of_the_Elves.cfg:726
msgid ""
"Though some of our number have fallen, many have escaped to safety! Our "
"archers and scouts both stand ready to join you on your journey."
msgstr ""
"Aínda que algúns dos nosos caeron, moitos escaparon a salvo! Os nosos "
"arqueiros e exploradores están preparados para unirse a vós na vosa viaxe."

#. [then]
#: data/campaigns/Heir_To_The_Throne/scenarios/02_Flight_of_the_Elves.cfg:728
msgid "Konrad can now recruit Elvish Archers and Scouts!"
msgstr "Konrad agora pode recrutar arqueiros e exploradores élficos!"

#. [message]: role=victory_speaker
#: data/campaigns/Heir_To_The_Throne/scenarios/02_Flight_of_the_Elves.cfg:736
msgid ""
"Though many of our number have fallen, at least some have escaped. Our "
"archers stand ready to join you on your journey."
msgstr ""
"Aínda que moitos dos nosos caeron, polo menos algúns escaparon. Os nosos "
"arqueiros están preparados para unirse a vós na vosa viaxe."

#. [then]
#: data/campaigns/Heir_To_The_Throne/scenarios/02_Flight_of_the_Elves.cfg:738
msgid "Konrad can now recruit Elvish Archers!"
msgstr "Konrad agora pode reclutar arqueiros elficos!"

#. [message]: role=victory_speaker
#: data/campaigns/Heir_To_The_Throne/scenarios/02_Flight_of_the_Elves.cfg:744
msgid ""
"Yet even with your aid, only a scant few of us elves have escaped. I fear "
"that none of our number can be spared to join you on your journey."
msgstr ""
"Con todo, mesmo co voso auxilio, só uns poucos de nós, os elfos, escapamos. "
"Temo que ningún dos nosos poida ser dispensado para acompañaros na vosa "
"viaxe."

#. [companion_message]
#: data/campaigns/Heir_To_The_Throne/scenarios/02_Flight_of_the_Elves.cfg:754
msgid ""
"Now, young prince, it is time for us to make our escape as well. Be swift — "
"make for the western forest!"
msgstr ""
"Agora, mozo príncipe, é hora de que nós tamén fuxamos. Sé rápido, diríxete "
"ao bosque occidental!"

#. [companion_message]
#: data/campaigns/Heir_To_The_Throne/scenarios/02_Flight_of_the_Elves.cfg:755
msgid ""
"Now it’s time for us to make our escape too. Quick, make for the western "
"forest!"
msgstr ""
"Agora é hora de que nós tamén fuxamos. Depresa, imos cara ao bosque "
"occidental!"

#. [scenario]
#: data/campaigns/Heir_To_The_Throne/scenarios/03_Blackwater_Port.cfg:15
msgid "scenario name^Blackwater Port"
msgstr "Porto de augas negras"

#. [side]: type=Orcish Warrior, id=Mokolo Qimur
#: data/campaigns/Heir_To_The_Throne/scenarios/03_Blackwater_Port.cfg:82
msgid "Mokolo Qimur"
msgstr "Mokolo Qimur"

#. [side]: type=Orcish Warrior, id=Mokolo Qimur
#. [side]: type={TYPE}, id={ID}
#: data/campaigns/Heir_To_The_Throne/scenarios/03_Blackwater_Port.cfg:88
#: data/campaigns/Heir_To_The_Throne/scenarios/10_Elensefar_Before.cfg:78
#: data/campaigns/Heir_To_The_Throne/scenarios/11_Elensefar_After.cfg:48
msgid "Clan Foxtail"
msgstr "Clan Foxtail"

#. [side]
#: data/campaigns/Heir_To_The_Throne/scenarios/03_Blackwater_Port.cfg:163
msgid "Rebels"
msgstr "Rebeldes"

#. [message]: speaker=Konrad {KONRAD_VARIATION concerned}
#: data/campaigns/Heir_To_The_Throne/scenarios/03_Blackwater_Port.cfg:300
msgid "Uncle Kaylan, we’re here! Are you alright? What can I do to help?"
msgstr "Tío Kaylan, estamos aquí! Estás ben? Que podo facer para axudar?"

#. [message]: speaker=Kaylan
#: data/campaigns/Heir_To_The_Throne/scenarios/03_Blackwater_Port.cfg:305
msgid ""
"Welcome Delfador, welcome Konrad! It is an honor to once again lay eyes upon "
"the true heir of Wesnoth. The false queen’s forces have caught us "
"unprepared, but the bulk of my riders shall soon return to rout the enemy "
"and seize our victory!"
msgstr ""
"Benvido, Delfador; benvido, Konrad! É unha honra volver ver ao verdadeiro "
"herdeiro de Wesnoth. As forzas da falsa raíña pilláronnos desprevidos, pero "
"a maior parte dos meus cabaleiros volverá pronto para derrotar o inimigo e "
"acadar a nosa vitoria!"

#. [message]: speaker=Delfador
#. after the player completes this scenario, Delfador leaves. Foreshadow that now.
#: data/campaigns/Heir_To_The_Throne/scenarios/03_Blackwater_Port.cfg:310
msgid ""
"How soon, Kaylan? I suspect Elensefar to be under siege as well — I cannot "
"leave Maddock to fight alone, yet neither can I leave the prince unguarded."
msgstr ""
"Canto tempo tardará, Kaylan? Sospeito que Elensefar tamén está asediada. Non "
"podo deixar a Maddock loitando só, pero tampouco podo deixar ao príncipe "
"desatendido."

#. [message]: speaker=Kaylan
#: data/campaigns/Heir_To_The_Throne/scenarios/03_Blackwater_Port.cfg:315
msgid ""
"Welcome, young Konrad! It is an honor to once again lay eyes upon the true "
"heir of Wesnoth. The false queen’s forces have caught us unprepared, but the "
"bulk of my riders shall soon return to rout the enemy and seize our victory!"
msgstr ""
"Benvido, novo Konrad! É unha honra volver ver ao verdadeiro herdeiro de "
"Wesnoth. As forzas da falsa raíña pilláronnos desprevidos, pero a maior "
"parte dos meus cabaleiros volverá pronto para derrotar o inimigo e acadar a "
"nosa vitoria!"

#. [message]: speaker=Konrad
#: data/campaigns/Heir_To_The_Throne/scenarios/03_Blackwater_Port.cfg:319
msgid ""
"I’m glad to be here, but sorry we couldn’t come sooner. For how long must we "
"defend before your reinforcements arrive?"
msgstr ""
"Alégrome de estar aquí, pero síntoo moito por non poder vir antes. Canto "
"tempo teremos que defender antes de que cheguen os vosos reforzos?"

#. [message]: speaker=Kaylan
#: data/campaigns/Heir_To_The_Throne/scenarios/03_Blackwater_Port.cfg:324
msgid ""
"If we can hold Blackwater for just a few more days, victory shall be "
"assured! I am encircled and trapped in the port, but with your help the "
"siege can be broken. Hearken to my words, Konrad, and Blackwater Port shall "
"yet endure!"
msgstr ""
"Se conseguimos manter Augas Negras só uns poucos días máis, a vitoria estará "
"asegurada! Estou rodeado e atrapado no porto, pero coa túa axuda o asedio "
"pódese romper. Escoita as miñas palabras, Konrad, e o Porto de Augas Negras "
"aínda perdurará!"

#. [objective]: condition=win
#: data/campaigns/Heir_To_The_Throne/scenarios/03_Blackwater_Port.cfg:333
#: data/campaigns/Heir_To_The_Throne/scenarios/07_Muff_Malals_Peninsula.cfg:290
#: data/campaigns/Heir_To_The_Throne/scenarios/10_Elensefar_Before.cfg:676
#: data/campaigns/Heir_To_The_Throne/scenarios/15b_Valley_of_Death_part2.cfg:352
#: data/campaigns/Heir_To_The_Throne/scenarios/48_Dan_Tonk.cfg:340
msgid "Survive until turns run out"
msgstr "Sobrevive ata o final das roldas"

#. [objective]: condition=win
#. [objective]: description=<span strikethrough='true' color='#A9A9A9'>, condition=win
#. if Kaylan is protected, Konrad will learn to recruit Cavalrymen and Horsemen
#: data/campaigns/Heir_To_The_Throne/scenarios/03_Blackwater_Port.cfg:340
#: data/campaigns/Heir_To_The_Throne/scenarios/03_Blackwater_Port.cfg:348
#, fuzzy
#| msgid "Protect Sir Kaylan (learn to recruit Cavalrymen and Horsemen)"
msgid "Protect Sir Kaylan: recruit Cavalrymen and Horsemen"
msgstr "Protexer a Sir Kaylan (aprender a recrutar cabaleiros e xinetes)"

#. [objective]: condition=win
#: data/campaigns/Heir_To_The_Throne/scenarios/03_Blackwater_Port.cfg:361
#: data/campaigns/Heir_To_The_Throne/scenarios/06_The_Isle_of_Alduin.cfg:306
#: data/campaigns/Heir_To_The_Throne/scenarios/08a_Isle_of_the_Damned_part1.cfg:287
#: data/campaigns/Heir_To_The_Throne/scenarios/11_Elensefar_After.cfg:336
#: data/campaigns/Heir_To_The_Throne/scenarios/15a_Valley_of_Death_part1.cfg:307
#: data/campaigns/Heir_To_The_Throne/scenarios/28_The_Lost_General.cfg:245
msgid "Defeat all enemy leaders"
msgstr "Derrota a todos os líderes inimigos"

#. [objective]: condition=win
#. This is an objective note. Completing this objective will be very hard, but you gain an early finish bonus and a loyal unit.
#: data/campaigns/Heir_To_The_Throne/scenarios/03_Blackwater_Port.cfg:363
msgid "(very hard: early finish bonus &#38; loyal companion)"
msgstr "(moi difícil: bonificación por remate anticipado e compañeiro leal)"

#. [message]: speaker=Kaylan
#: data/campaigns/Heir_To_The_Throne/scenarios/03_Blackwater_Port.cfg:383
msgid ""
"Brothers-in-arms, fighting side-by-side! Not since the death of the old king "
"have I felt this way, young Konrad. If I have but one regret in my life, it "
"is that I could not raise you here as my own."
msgstr ""
"Irmáns de armas, loitando cóbado con cóbado! Desde a morte do vello rei non "
"me sentín así, mozo Konrad. Se só teño un arrepentimento na miña vida, é non "
"poder criarte aquí como se fose meu fillo."

#. [message]: speaker=Konrad
#: data/campaigns/Heir_To_The_Throne/scenarios/03_Blackwater_Port.cfg:387
msgid ""
"Master Delfador told me: You wanted to raise me in Blackwater Port among "
"other humans, but he felt it was too dangerous."
msgstr ""
"O mestre Delfador díxome: Querías criarme en Porto de Augas Negras entre "
"outros humanos, pero el consideraba que era demasiado perigoso."

#. [message]: speaker=Konrad
#: data/campaigns/Heir_To_The_Throne/scenarios/03_Blackwater_Port.cfg:391
msgid ""
"I don’t mind though. I like elves, and we still got to come visit you "
"sometimes."
msgstr ""
"Pero non me importa. Gústanme os elfos, e aínda temos que vir visitarte ás "
"veces."

#. [message]: speaker=Delfador
#: data/campaigns/Heir_To_The_Throne/scenarios/03_Blackwater_Port.cfg:395
msgid ""
"And I was quite right, too. A military town is no place for a young child; "
"Blackwater Port has seen its fair share of battles since I first rescued "
"you, Konrad."
msgstr ""
"E eu tamén tiña razón. Unha cidade militar non é lugar para un neno pequeno; "
"Porto de Augas Negras viu a súa boa dose de batallas desde que te rescatei "
"por primeira vez, Konrad."

#. [event]
#: data/campaigns/Heir_To_The_Throne/scenarios/03_Blackwater_Port.cfg:406
msgid "Vygwyn"
msgstr "Vygwyn"

#. [event]
#: data/campaigns/Heir_To_The_Throne/scenarios/03_Blackwater_Port.cfg:407
msgid "Gaebryn"
msgstr "Gaebryn"

#. [message]: speaker=Vygwyn
#: data/campaigns/Heir_To_The_Throne/scenarios/03_Blackwater_Port.cfg:411
msgid ""
"Hail, Sir Kaylan! We rode as swiftly as we could, and come to aid in the "
"defense! The others will arrive soon — do not despair!"
msgstr ""
"Salve, Sir Kaylan! Cabalgamos tan rápido como puidemos e vimos axudar na "
"defensa! Os demais chegarán axiña. Non desesperes!"

#. [message]: speaker=Vygwyn
#: data/campaigns/Heir_To_The_Throne/scenarios/03_Blackwater_Port.cfg:416
#, fuzzy
#| msgid ""
#| "Hail, is anyone still alive? We rode as swiftly as we could, and come to "
#| "aid in the defense. Do not despair — the rest of your reinforcements will "
#| "soon arrive"
msgid ""
"Hail, is anyone still alive? We rode as swiftly as we could, and come to aid "
"in the defense. Do not despair — the rest of your reinforcements will soon "
"arrive!"
msgstr ""
"Ola, aínda hai alguén vivo? Cabalgamos o máis rápido que puidemos e viñemos "
"axudar na defensa. Non desesperes: o resto dos teus reforzos chegará axiña."

