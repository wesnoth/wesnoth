#: data/campaigns/Eastern_Invasion/utils/items.cfg:1132
msgid "Elixir of Water Breathing"
msgstr "Elixir de Respiração Aquática"

#: data/campaigns/Eastern_Invasion/utils/items.cfg:1133
msgid ""
"This shimmering blue vial grants its drinker normal movement and defense in "
"swamp and shallow water."
msgstr ""
"Este frasco de elixir azul cintilante garante a quem o beber movimento e "
"defesa normal em pântanos e águas rasas."

#. [floating_text]
#: data/campaigns/Eastern_Invasion/utils/items.cfg:1153
