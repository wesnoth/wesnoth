#: data/campaigns/Dusk_of_Dawn/scenarios/03_Fateful_Day.cfg:197
#: data/campaigns/Dusk_of_Dawn/scenarios/04_A_Beautiful_World.cfg:86
msgid "Red Cry Horde"
msgstr ""

#. [side]: type=Orcish Warlord, id=AR
#. [unit]: type=Orcish Warlord, id=AR
#: data/campaigns/Dusk_of_Dawn/scenarios/03_Fateful_Day.cfg:156
#: data/campaigns/Dusk_of_Dawn/scenarios/04_A_Beautiful_World.cfg:276
msgid "Agnar Red Cry"
msgstr ""

#. [side]: type=Orcish Warlord, id=AR
#: data/campaigns/Dusk_of_Dawn/scenarios/03_Fateful_Day.cfg:182
msgid "Omag"
msgstr ""

#. [side]: type=Goblin Pillager, id=NG
#: data/campaigns/Dusk_of_Dawn/scenarios/03_Fateful_Day.cfg:203
msgid "Nuug The Firebug"
msgstr ""

#. [side]: type=Goblin Pillager, id=NG
#: data/campaigns/Dusk_of_Dawn/scenarios/03_Fateful_Day.cfg:229
msgid "Uod"
msgstr ""

#. [side]: type=Goblin Pillager, id=NG
#: data/campaigns/Dusk_of_Dawn/scenarios/03_Fateful_Day.cfg:230
msgid "Marl"
msgstr ""

#. [side]: type=Saurian Oracle, id=MZ
#. [side]
#: data/campaigns/Dusk_of_Dawn/scenarios/03_Fateful_Day.cfg:245
#: data/campaigns/Dusk_of_Dawn/scenarios/04_A_Beautiful_World.cfg:98
msgid "Blue Blood Saurians"
msgstr ""

#. [side]: type=Saurian Oracle, id=MZ
#. [unit]: type=Saurian Oracle, id=MZ
#: data/campaigns/Dusk_of_Dawn/scenarios/03_Fateful_Day.cfg:251
#: data/campaigns/Dusk_of_Dawn/scenarios/04_A_Beautiful_World.cfg:312
msgid "Moarxz Blue Blood"
msgstr ""

#. [side]: type=Saurian Oracle, id=MZ
#: data/campaigns/Dusk_of_Dawn/scenarios/03_Fateful_Day.cfg:277
msgid "Zarx"
msgstr ""

#. [side]: type=Saurian Oracle, id=MZ
#: data/campaigns/Dusk_of_Dawn/scenarios/03_Fateful_Day.cfg:278
msgid "Azzaris"
msgstr ""

#. [side]: type=Saurian Oracle, id=MZ
#: data/campaigns/Dusk_of_Dawn/scenarios/03_Fateful_Day.cfg:279
msgid "Sonikss"
msgstr ""

#. [objective]: condition=win
#: data/campaigns/Dusk_of_Dawn/scenarios/03_Fateful_Day.cfg:291
#: data/campaigns/Dusk_of_Dawn/scenarios/03_Fateful_Day.cfg:641
msgid "Defeat every enemy unit"
msgstr ""

#. [objective]: condition=lose
#: data/campaigns/Dusk_of_Dawn/scenarios/03_Fateful_Day.cfg:299
#: data/campaigns/Dusk_of_Dawn/scenarios/03_Fateful_Day.cfg:649
msgid "Death of Sessa"
msgstr ""

#. [note]
#: data/campaigns/Dusk_of_Dawn/scenarios/03_Fateful_Day.cfg:308
#: data/campaigns/Dusk_of_Dawn/scenarios/03_Fateful_Day.cfg:658
msgid ""
"Ougl’s control over fire has improved. Fire guardians can now move faster in "
"cave terrain."
msgstr ""

#. [note]
#: data/campaigns/Dusk_of_Dawn/scenarios/03_Fateful_Day.cfg:312
#: data/campaigns/Dusk_of_Dawn/scenarios/03_Fateful_Day.cfg:662
msgid "Ally and enemy guard units have 0 movement points."
msgstr ""

#. [message]: speaker=narrator
#: data/campaigns/Dusk_of_Dawn/scenarios/03_Fateful_Day.cfg:351
msgid "Drums could be heard in the distance."
msgstr ""

#. [message]: speaker=narrator
#: data/campaigns/Dusk_of_Dawn/scenarios/03_Fateful_Day.cfg:367
msgid "It didn’t take long for the trolls to understand what was happening."
msgstr ""

#. [message]: speaker=narrator
#: data/campaigns/Dusk_of_Dawn/scenarios/03_Fateful_Day.cfg:401
msgid ""
"Some creatures were about to attack some other creatures. Both creatures’ "
"appearances were strange and monstrous."
msgstr ""

#. [message]: speaker=narrator
#: data/campaigns/Dusk_of_Dawn/scenarios/03_Fateful_Day.cfg:407
msgid "However, Ougl could feel who was not driven by a good heart."
msgstr ""

#. [message]: speaker=SA
#: data/campaigns/Dusk_of_Dawn/scenarios/03_Fateful_Day.cfg:417
msgid "<b>S s a s...! ?</b> (Another enemy!?)"
msgstr ""

#. [message]: speaker=narrator
#: data/campaigns/Dusk_of_Dawn/scenarios/03_Fateful_Day.cfg:430
msgid "Ougl shook his head in denial."
msgstr ""

#. [message]: speaker=SA
#: data/campaigns/Dusk_of_Dawn/scenarios/03_Fateful_Day.cfg:435
msgid "<b>S s a s...?</b> (A friend, then?)"
msgstr ""

#. [message]: speaker=narrator
#: data/campaigns/Dusk_of_Dawn/scenarios/03_Fateful_Day.cfg:448
msgid "Ougl nodded."
msgstr ""

#. [message]: speaker=AR
#: data/campaigns/Dusk_of_Dawn/scenarios/03_Fateful_Day.cfg:458
msgid ""
"<b>Arg-hah!</b> (There is no more hope for you. No matter how many help you, "
"death awaits you anyway.)"
msgstr ""

#. [message]: speaker=MZ
#: data/campaigns/Dusk_of_Dawn/scenarios/03_Fateful_Day.cfg:468
msgid "<b>S y s s...!</b> (Give up your treasures and we will spare you!)"
msgstr ""

#. [message]: speaker=SA
#: data/campaigns/Dusk_of_Dawn/scenarios/03_Fateful_Day.cfg:473
msgid "<b>S s a s...!</b> (Never!)"
msgstr ""

#. [message]: speaker=NG
#: data/campaigns/Dusk_of_Dawn/scenarios/03_Fateful_Day.cfg:478
msgid "<b>Urg-hah!</b> (Then die!)"
msgstr ""

#. [message]: speaker=narrator
#: data/campaigns/Dusk_of_Dawn/scenarios/03_Fateful_Day.cfg:496
msgid "The Nagini looked again at the trolls."
msgstr ""

#. [message]: speaker=SA
#: data/campaigns/Dusk_of_Dawn/scenarios/03_Fateful_Day.cfg:501
msgid "<b>S s a s...?</b> (Will you help us?)"
msgstr ""

#. [message]: speaker=narrator
#: data/campaigns/Dusk_of_Dawn/scenarios/03_Fateful_Day.cfg:514
msgid "Ougl said only one thing."
msgstr ""

#. [message]: speaker=RE
#: data/campaigns/Dusk_of_Dawn/scenarios/03_Fateful_Day.cfg:547
msgid "<b>S y s y...!</b> (I want to fight too!)"
msgstr ""

#. [message]: speaker=RE
#: data/campaigns/Dusk_of_Dawn/scenarios/03_Fateful_Day.cfg:559
msgid "<b>S y s y...</b> (Let me deal with this one.)"
msgstr ""

#. [message]: speaker=unit
#. [message]: speaker=OL
#: data/campaigns/Dusk_of_Dawn/scenarios/03_Fateful_Day.cfg:619
#: data/campaigns/Dusk_of_Dawn/scenarios/03_Fateful_Day.cfg:1054
#: data/campaigns/Dusk_of_Dawn/scenarios/03_Fateful_Day.cfg:1073
msgid "...!"
msgstr ""

#. [message]: speaker=narrator
#: data/campaigns/Dusk_of_Dawn/scenarios/03_Fateful_Day.cfg:630
msgid ""
"The hungry troll gorged itself on the mushrooms. They weren’t very tasty. "
"Could they have been poisonous?"
msgstr ""

#. [message]: speaker=narrator
#: data/campaigns/Dusk_of_Dawn/scenarios/03_Fateful_Day.cfg:636
msgid "The troll suddenly feels an overwhelming rage."
msgstr ""

#. [note]
#: data/campaigns/Dusk_of_Dawn/scenarios/03_Fateful_Day.cfg:666
msgid ""
"In this scenario, trolls entering mushroom terrain will destroy the "
"mushrooms and gain berserk on their melee attacks."
msgstr ""

#. [message]: speaker=narrator
#: data/campaigns/Dusk_of_Dawn/scenarios/03_Fateful_Day.cfg:683
msgid ""
"Ougl bit into a piece of mushroom, but as soon as he tasted it, he spat it "
"out in disgust. He was not interested in rage."
msgstr ""

#. [message]: speaker=narrator
#: data/campaigns/Dusk_of_Dawn/scenarios/03_Fateful_Day.cfg:831
msgid ""
"Drums once again echoed through the cavern. Enemy reinforcements had arrived."
msgstr ""

#. [message]: speaker=AR
#: data/campaigns/Dusk_of_Dawn/scenarios/03_Fateful_Day.cfg:857
msgid "<b>Arg-hah!</b> (I won’t lose!)"
msgstr ""

#. [message]: speaker=AR
#: data/campaigns/Dusk_of_Dawn/scenarios/03_Fateful_Day.cfg:869
msgid "<b>Arg-hah!</b> (You’ll pay for this, you dirty troll!)"
msgstr ""

#. [message]: speaker=NG
#: data/campaigns/Dusk_of_Dawn/scenarios/03_Fateful_Day.cfg:895
msgid "<b>Urg-hah...</b> (No! I can’t die...)"
msgstr ""

#. [message]: speaker=MZ
#: data/campaigns/Dusk_of_Dawn/scenarios/03_Fateful_Day.cfg:921
msgid "<b>S y s s...!</b> (Time to retreat!)"
msgstr ""

#. [message]: speaker=SA
#: data/campaigns/Dusk_of_Dawn/scenarios/03_Fateful_Day.cfg:937
msgid "<b>S s a s...!</b> (What a coward!)"
msgstr ""

#. [message]: speaker=RE
#: data/campaigns/Dusk_of_Dawn/scenarios/03_Fateful_Day.cfg:949
msgid "<b>S y s y...</b> (Forgive me for falling...)"
msgstr ""

#. [message]: speaker=RE
#: data/campaigns/Dusk_of_Dawn/scenarios/03_Fateful_Day.cfg:968
msgid "<b>S y s y...</b> (You are a fool of a saurian.)"
msgstr ""

#. [message]: speaker=MZ
#: data/campaigns/Dusk_of_Dawn/scenarios/03_Fateful_Day.cfg:977
msgid "<b>S y s s...!</b> (No, you are. You saurian traitor!)"
msgstr ""

#. [message]: speaker=RE
#: data/campaigns/Dusk_of_Dawn/scenarios/03_Fateful_Day.cfg:986
msgid "<b>S y s y...!</b> (You are, not me!)"
msgstr ""

#. [message]: speaker=MZ
#: data/campaigns/Dusk_of_Dawn/scenarios/03_Fateful_Day.cfg:1000
msgid "<b>S y s s...!</b> (You are annoying...)"
msgstr ""

#. [message]: speaker=RE
#: data/campaigns/Dusk_of_Dawn/scenarios/03_Fateful_Day.cfg:1014
msgid "<b>S y s y...</b> (You are more.)"
msgstr ""

#. [message]: speaker=RE
#: data/campaigns/Dusk_of_Dawn/scenarios/03_Fateful_Day.cfg:1023
msgid "<b>S s s s y s y s s y y...!</b> (Saurian insult, no translation.)"
msgstr ""

#. [message]: speaker=MZ
#: data/campaigns/Dusk_of_Dawn/scenarios/03_Fateful_Day.cfg:1032
msgid "<b>S y s s...</b> (How dare you!)"
msgstr ""

#. [message]: speaker=SA
#: data/campaigns/Dusk_of_Dawn/scenarios/03_Fateful_Day.cfg:1049
msgid "<b>S s a s...</b> (It’s over...)"
msgstr ""

#. [message]: speaker=narrator
#: data/campaigns/Dusk_of_Dawn/scenarios/03_Fateful_Day.cfg:1101
msgid ""
"Ougl gave a victorious roar as the last of his enemies fell to the ground."
msgstr ""

#. [message]: speaker=SA
#: data/campaigns/Dusk_of_Dawn/scenarios/03_Fateful_Day.cfg:1111
msgid ""
"<b>S s a s...</b> (Thank you for your help. Without your aid we would have "
"been routed.)"
msgstr ""

#. [message]: speaker=SA
#: data/campaigns/Dusk_of_Dawn/scenarios/03_Fateful_Day.cfg:1116
msgid "<b>S s a s...</b> (How can we repay you?)"
msgstr ""

#. [message]: speaker=narrator
#: data/campaigns/Dusk_of_Dawn/scenarios/03_Fateful_Day.cfg:1122
msgid "Ougl already knew how the Naga could help him."
msgstr ""

#. [scenario]: id=04_A_Beautiful_World
#: data/campaigns/Dusk_of_Dawn/scenarios/04_A_Beautiful_World.cfg:5
msgid "A Beautiful World"
msgstr ""

#. [part]
#: data/campaigns/Dusk_of_Dawn/scenarios/04_A_Beautiful_World.cfg:20
msgid ""
"Sessa asked the trolls how she could repay them for their help, but the "
"trolls did not know how to speak. They pointed upwards with their hands."
msgstr ""

#. [part]
#: data/campaigns/Dusk_of_Dawn/scenarios/04_A_Beautiful_World.cfg:24
msgid ""
"Fortunately, this was not the first time the Nagas had met their kind, and "
"after a while they understood where the trolls were going."
msgstr ""

#. [part]
#: data/campaigns/Dusk_of_Dawn/scenarios/04_A_Beautiful_World.cfg:29
msgid ""
"The old wose’s directions had been too complicated for Ougl to follow. He "
"had forgotten most of them already. But with a guide, the trolls would "
"surely reach their goal."
msgstr ""

#. [unit]: type=Naga Fighter, id=IA, gender=female
#: data/campaigns/Dusk_of_Dawn/scenarios/04_A_Beautiful_World.cfg:64
msgid "Ilaja"
msgstr ""

#. [message]: speaker=IA
#: data/campaigns/Dusk_of_Dawn/scenarios/04_A_Beautiful_World.cfg:143
msgid "<b>S s a s...</b> (Here we bid farewell, stone friends. Be safe.)"
msgstr ""

#. [message]: speaker=narrator
#: data/campaigns/Dusk_of_Dawn/scenarios/04_A_Beautiful_World.cfg:167
msgid ""
"Ougl took a step towards the exit, but hesitated for a moment. He wasn’t "
"sure why."
msgstr ""

#. [message]: speaker=narrator
#: data/campaigns/Dusk_of_Dawn/scenarios/04_A_Beautiful_World.cfg:226
msgid ""
"The outside world was everything Ougl had imagined. Green. Full of sound and "
"life. Ougl and the Golden Flame Tribe were filled with awe."
msgstr ""

#. [message]: speaker=narrator
#: data/campaigns/Dusk_of_Dawn/scenarios/04_A_Beautiful_World.cfg:248
msgid ""
"A bright light shone overhead, brighter than anything Ougl had ever seen. "
"The light hurt to look at. The light made everything hurt to look at, but "
"Ougl kept looking anyway."
msgstr ""

#. [message]: speaker=narrator
#: data/campaigns/Dusk_of_Dawn/scenarios/04_A_Beautiful_World.cfg:262
msgid ""
"Ougl’s voice ran out with joy. He felt that he had fulfilled his greatest "
"dream."
msgstr ""

#. [message]: speaker=narrator
#: data/campaigns/Dusk_of_Dawn/scenarios/04_A_Beautiful_World.cfg:268
msgid "But his happiness did not last very long..."
msgstr ""

#. [message]: speaker=AR
#: data/campaigns/Dusk_of_Dawn/scenarios/04_A_Beautiful_World.cfg:294
msgid "<b>Arg-hah!</b> (Now we've got you! You dumb troll!)"
msgstr ""

#. [modify_side]
#: data/campaigns/Dusk_of_Dawn/scenarios/04_A_Beautiful_World.cfg:393
msgid "Flameless Tribe"
msgstr ""

#. [modify_unit]
#: data/campaigns/Dusk_of_Dawn/scenarios/04_A_Beautiful_World.cfg:401
msgid "Ougl the Flameless"
msgstr ""

#. [message]: speaker=narrator
#: data/campaigns/Dusk_of_Dawn/scenarios/04_A_Beautiful_World.cfg:484
msgid ""
"The saurian stole away Ougl’s inner flame and quenched it with magic. Bitter "
"cold cut into Ougl’s stone-like body."
msgstr ""

#. [message]: speaker=MZ
#: data/campaigns/Dusk_of_Dawn/scenarios/04_A_Beautiful_World.cfg:489
msgid ""
"<b>S y s s...</b> (You will follow us wherever we go if you want to regain "
"your inner flame, troll.)"
msgstr ""

#. [message]: speaker=narrator
#: data/campaigns/Dusk_of_Dawn/scenarios/04_A_Beautiful_World.cfg:495
msgid "...But Ougl had no intention of giving up so easily."
msgstr ""

#. [message]: speaker=narrator
#: data/campaigns/Dusk_of_Dawn/scenarios/04_A_Beautiful_World.cfg:501
msgid "He suddenly shouted. Trollish words rang out in the evening air."
msgstr ""

#. [message]: speaker=OL
#: data/campaigns/Dusk_of_Dawn/scenarios/04_A_Beautiful_World.cfg:510
msgid "OUGL... NOT FOLLOW YOU!!!"
msgstr ""

#. [message]: speaker=AR
#: data/campaigns/Dusk_of_Dawn/scenarios/04_A_Beautiful_World.cfg:553
msgid "<b>Arg-hah!</b> (The beast is trying to fight! Archers, to me!)"
msgstr ""

#. [message]: speaker=narrator
#: data/campaigns/Dusk_of_Dawn/scenarios/04_A_Beautiful_World.cfg:640
msgid "When Ougl felt the heat of the fire, he flew into a great rage."
msgstr ""

#. [message]: speaker=narrator
#: data/campaigns/Dusk_of_Dawn/scenarios/04_A_Beautiful_World.cfg:906
msgid ""
"Ougl fell to his knees. The strong troll’s gaze became absent, and his will "
"to fight died out. His drive and vitality had faded away, and only empty "
"space remained in his heart."
msgstr ""

#. [message]: speaker=AR
#: data/campaigns/Dusk_of_Dawn/scenarios/04_A_Beautiful_World.cfg:913
msgid ""
"<b>Arg-hah!</b> (You have no chance to win against me. Do you understand? "
"Ha, ha, ha...!)"
msgstr ""

#. [message]: speaker=AR
#: data/campaigns/Dusk_of_Dawn/scenarios/04_A_Beautiful_World.cfg:920
msgid ""
"<b>Arg-hah!</b> (Now your leader is under our power. You trolls need a new "
"leader. You will all follow us!)"
msgstr ""

#. [message]: speaker=narrator
#: data/campaigns/Dusk_of_Dawn/scenarios/04_A_Beautiful_World.cfg:933
msgid ""
"None of the Golden Flame Tribe were as bright or as bold as Ougl had been. "
"They did not understand the danger of the orcs."
msgstr ""

#. [message]: speaker=narrator
#: data/campaigns/Dusk_of_Dawn/scenarios/04_A_Beautiful_World.cfg:939
msgid ""
"The trolls joined their new leaders, and learned from them. They learned to "
"lust for the sheen of gold and the smell of blood. They learned to spread "
"ruin and death."
msgstr ""

#. [unit]: type=Elder Mage, id=CU
#. [message]: speaker=narrator
#: data/campaigns/Dusk_of_Dawn/scenarios/04_A_Beautiful_World.cfg:1008
#: data/campaigns/Dusk_of_Dawn/scenarios/04_A_Beautiful_World.cfg:1041
#: data/campaigns/Dusk_of_Dawn/scenarios/04_A_Beautiful_World.cfg:1048
msgid "Crelanu"
msgstr ""

#. [message]: speaker=narrator
#: data/campaigns/Dusk_of_Dawn/scenarios/04_A_Beautiful_World.cfg:1043
msgid ""
"Some years later, a few members of the unfortunate Golden Flame Tribe found "
"themselves in the far north, besieging my wizard’s tower as orcs so often do."
msgstr ""

#. [message]: speaker=narrator
#: data/campaigns/Dusk_of_Dawn/scenarios/04_A_Beautiful_World.cfg:1050
msgid ""
"Their attack failed. I took prisoners, from whom I learned this story. And "
"now you have learned it from me."
msgstr ""

#. [message]: speaker=narrator
#: data/campaigns/Dusk_of_Dawn/scenarios/04_A_Beautiful_World.cfg:1062
msgid ""
"Trolls are often thought of as beasts, bloodthirsty monsters who only do bad "
"things. Perhaps many are. But many were not always so."
msgstr ""

#. [scenario]: id=Secret
#: data/campaigns/Dusk_of_Dawn/scenarios/Secret.cfg:5
msgid "Secret"
msgstr ""

#. [part]
#: data/campaigns/Dusk_of_Dawn/scenarios/Secret.cfg:20
msgid "Dwarves are a very cautious folk, carefully guarding their secrets."
msgstr ""

#. [part]
#: data/campaigns/Dusk_of_Dawn/scenarios/Secret.cfg:24
msgid ""
"They are well known for frantically mining treasures and adorning themselves "
"with jewels. Less well known is that they practice a mysterious kind of "
"magic."
msgstr ""

#. [part]
#: data/campaigns/Dusk_of_Dawn/scenarios/Secret.cfg:28
msgid ""
"It is said that when the earliest dwarves first came up from the deep, they "
"left behind a primordial power far below. Through the art of runes, dwarves "
"create energy channels that carry fragments of this power up to the surface "
"world."
msgstr ""

#. [part]
#: data/campaigns/Dusk_of_Dawn/scenarios/Secret.cfg:33
msgid ""
"Descending deeper through the trapdoor, Ougl became the first of the Golden "
"Flame Tribe to see this art in action."
msgstr ""

#. [side]
#: data/campaigns/Dusk_of_Dawn/scenarios/Secret.cfg:61
msgid "Guardian of the Secret Room"
msgstr ""

#. [side]
#. [unit]: type=Stone Golem, id=STONE-HEART
#: data/campaigns/Dusk_of_Dawn/scenarios/Secret.cfg:80
#: data/campaigns/Dusk_of_Dawn/scenarios/Secret.cfg:771
msgid "Stone Heart"
msgstr ""

#. [objective]: condition=win
#: data/campaigns/Dusk_of_Dawn/scenarios/Secret.cfg:92
msgid "Reach the artifact (10,2)"
msgstr ""

#. [note]
#: data/campaigns/Dusk_of_Dawn/scenarios/Secret.cfg:106
msgid ""
"The golem moves towards you each turn. It has 1 MP, which will increase by 1 "
"each time it enters a tile with a rune."
msgstr ""

#. [note]
#: data/campaigns/Dusk_of_Dawn/scenarios/Secret.cfg:110
msgid "To open the gate you need to trigger buttons: (5,7) and (15,7)."
msgstr ""

#. [message]: speaker=narrator
#: data/campaigns/Dusk_of_Dawn/scenarios/Secret.cfg:604
msgid ""
"The stone statue came suddenly to life. Its eyes lit up with a bright glow."
msgstr ""

#. [message]: speaker=narrator
#: data/campaigns/Dusk_of_Dawn/scenarios/Secret.cfg:622
msgid ""
"Ougl was sure that there must be something very valuable locked away behind "
"the guardian statue. He wanted the treasure hidden by the dwarves."
msgstr ""

#. [message]: speaker=narrator
#: data/campaigns/Dusk_of_Dawn/scenarios/Secret.cfg:631
msgid "But first he had to open the way by pressing two stone buttons."
msgstr ""

#. [message]: speaker=narrator
#: data/campaigns/Dusk_of_Dawn/scenarios/Secret.cfg:652
msgid ""
"This amulet radiates an aura of power. It is engraved with the head of a "
"raven, birds that have been great allies of the dwarves since time "
"immemorial."
msgstr ""

#. [message]: speaker=narrator
#: data/campaigns/Dusk_of_Dawn/scenarios/Secret.cfg:711
msgid ""
"The moment Ougl’s fingers touch the amulet, the golem suddenly crumbles into "
"fine dust."
msgstr ""

#. [message]: speaker=narrator
#: data/campaigns/Dusk_of_Dawn/scenarios/Secret.cfg:765
msgid "Through the art of runes, the dust begins to gather again..."
msgstr ""

#. [message]: speaker=narrator
#: data/campaigns/Dusk_of_Dawn/scenarios/Secret.cfg:787
msgid "...and a new golem loyal to Ougl is born."
msgstr ""

#. [message]: speaker=narrator
#: data/campaigns/Dusk_of_Dawn/scenarios/Secret.cfg:900
#: data/campaigns/Dusk_of_Dawn/scenarios/Secret.cfg:952
msgid "With a squeal of rusty machinery, the gate opens."
msgstr ""

